!<DOCTYPE html>
<html>
<head>
  <title>SoundNest - Vinili</title>
  <style>
    body {
      background-color: #f0f2f5;
      font-family: Arial;
      text-align: center;
    }

    .container {
      display: flex;
      justify-content: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .card {
      background-color: white;
      width: 250px;
      margin: 20px;
      padding: 15px;
      border-radius: 15px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    .card img {
      width: 100%;
      border-radius: 10px;
    }

    .card:hover {
      transform: scale(1.05);
    }

    button {
      background-color: darkblue;
      color: white;
      border: none;
      padding: 10px;
      border-radius: 8px;
      cursor: pointer;
    }

    #carrello {
      background: white;
      width: 300px;
      margin: 20px auto;
      padding: 15px;
      border-radius: 10px;
    }
  </style>
</head>

<body>

<header>
  <h1>SoundNest</h1>

  <nav>
    <a href="index.html">Home</a>
    <a href="vinili.html">Vinili</a>
    <a href="login.html">Login</a>
  </nav>
</header>

<main>

  <h2>Vinili in evidenza</h2>

  <!-- 🛒 CARRELLO -->
  <div id="carrello">
    <h3>🛒 Carrello</h3>
    <ul id="lista-carrello"></ul>
    <p>Totale: <span id="totale">0</span>€</p>
  </div>

<a href="checkout.html">
 <button>Vai al checkout</button>
</a>


  <!-- 🎵 PRODOTTI -->
  <div class="container">

    <div class="card">
      <img src="data:image/jpeg;base64," alt="Thriller">
      <h3>Thriller</h3>
      <p>Michael Jackson</p>
      <p>25€</p>
      <button onclick="aggiungi('Thriller', 25)">Compra</button>
    </div>

    <div class="card">
      <img src="data:image/jpeg;base64," alt="Utopia">
      <h3>Utopia</h3>
      <p>Travis Scott</p>
      <p>30€</p>
      <button onclick="aggiungi('Utopia', 30)">Compra</button>
    </div>

  </div>

</main>

<footer>
  <p>© SoundNest</p>
</footer>

<script>
let totale = 0;

function aggiungi(nome, prezzo){
  totale += prezzo;
  document.getElementById("totale").innerText = totale;

  let item = document.createElement("li");
  item.innerText = nome + " - " + prezzo + "€";

  let lista = document.getElementById("lista-carrello");
  lista.appendChild(item);
}
</script>

</body>
